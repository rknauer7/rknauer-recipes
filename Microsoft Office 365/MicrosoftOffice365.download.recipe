<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Description</key>
    <string>Downloads the latest Microsoft Office 365 Suite installer package using Microsoft's official product feed query.</string>
    <key>Identifier</key>
    <string>com.github.rknauer.MicrosoftOffice365.download.recipe</string>
    <key>Input</key>
    <dict>
        <key>NAME</key>
        <string>Microsoft Office 365</string>
    </dict>
    <key>MinimumVersion</key>
    <string>2.0.0</string>
    <key>Process</key>
    <array>
        <dict>
            <key>Processor</key>
            <string>URLTextSearcher</string>
            <key>Arguments</key>
            <dict>
                <key>url</key>
                <string>https://macadmins.software/latest.xml</string>
                <key>re_pattern</key>
                <string>&lt;id&gt;com\.microsoft\.office\.suite\.2016&lt;/id&gt;\s*&lt;version&gt;(?P&lt;version&gt;[0-9\.]+)&lt;/version&gt;\s*&lt;url&gt;(?P&lt;url&gt;https://go\.microsoft\.com/fwlink/\?linkid=[0-9]+)&lt;/url&gt;</string>
            </dict>
        </dict>
        <dict>
            <key>Processor</key>
            <string>URLDownloader</string>
            <key>Arguments</key>
            <dict>
                <key>filename</key>
                <string>Office365Suite.pkg</string>
            </dict>
        </dict>
        <dict>
            <key>Processor</key>
            <string>EndOfCheckPhase</string>
        </dict>
        <dict>
            <key>Processor</key>
            <string>CodeSignatureVerifier</string>
            <key>Arguments</key>
            <dict>
                <key>input_path</key>
                <string>%pathname%</string>
                <key>expected_authority_names</key>
                <array>
                    <string>Developer ID Installer: Microsoft Corporation (UBF8T346G9)</string>
                    <string>Apple Root CA</string>
                </array>
            </dict>
        </dict>
    </array>
</dict>
</plist>
