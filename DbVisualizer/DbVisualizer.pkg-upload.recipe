<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Description</key>
    <string>Uploads the DbVisualizer package to Jamf Pro.</string>
    <key>Identifier</key>
    <string>com.github.rknauer.DbVisualizer.pkg-upload.recipe</string>
    <key>Input</key>
    <dict>
        <key>CATEGORY</key>
        <string>Apps</string>
    </dict>
    <key>MinimumVersion</key>
    <string>2.0.0</string>
    <key>ParentRecipe</key>
    <string>com.github.rknauer.DbVisualizer.download.recipe</string>
    <key>Process</key>
    <array>
        <dict>
            <key>Processor</key>
            <string>com.github.grahampugh.jamf-upload.processors/JamfPackageUploader</string>
            <key>Arguments</key>
            <dict>
                <key>pkg_category</key>
                <string>%CATEGORY%</string>
                <key>pkg_name</key>
                <string>%NAME%-%version%.pkg</string>
            </dict>
        </dict>
    </array>
</dict>
</plist>
